/**
 * Entity-scoped error codes for <%= Entity %>. Registered into the shared
 * @peruri/ts-lib apperr registry at module load (the analogue of the Go init()
 * registration). Import this module for its side effect in the composition root.
 *
 * Codes start at a per-entity base offset to avoid colliding with the library's
 * built-in codes — mirrors the Go iota+1000 convention.
 */
import { CodeErrEnum, appendCodeErrMap } from '@peruri/ts-lib/apperr';

const BASE = <%= ApperrBase %>;

export const Err<%= Entity %>NotFound = (BASE + 0) as CodeErrEnum;
export const Err<%= Entity %>Duplicate = (BASE + 1) as CodeErrEnum;
export const Err<%= Entity %>MissingID = (BASE + 2) as CodeErrEnum;
export const Err<%= Entity %>ConstraintViolation = (BASE + 3) as CodeErrEnum;

appendCodeErrMap(Err<%= Entity %>NotFound, {
  message: '<%= EntityLower %> not found',
  code: 'ERR404100',
  statusCode: 404,
});
appendCodeErrMap(Err<%= Entity %>Duplicate, {
  message: '<%= EntityLower %> already exists',
  code: 'ERR409100',
  statusCode: 409,
});
appendCodeErrMap(Err<%= Entity %>MissingID, {
  message: '<%= EntityLower %> id is required',
  code: 'ERR400100',
  statusCode: 400,
});
appendCodeErrMap(Err<%= Entity %>ConstraintViolation, {
  message: '<%= EntityLower %> violates a database constraint',
  code: 'ERR400101',
  statusCode: 400,
});
