services:
<% if (Database !== 'none') { %>  postgres:
    image: postgres:16-alpine
    container_name: <%= Name %>-postgres
    environment:
      POSTGRES_USER: admin
      POSTGRES_PASSWORD: admin
      POSTGRES_DB: appdb
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U admin -d appdb"]
      interval: 5s
      timeout: 3s
      retries: 10
<% } %><% if (Cache === 'redis') { %>  redis:
    image: redis:7-alpine
    container_name: <%= Name %>-redis
    command: ["redis-server", "--requirepass", "admin"]
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "-a", "admin", "ping"]
      interval: 5s
      timeout: 3s
      retries: 10
<% } %>