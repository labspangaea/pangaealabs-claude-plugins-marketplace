services:
{{- if ne .Database "none" }}
{{- if eq .Database "gorm-postgres" }}
  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: {{.EntityLower}}_db
    ports:
      - "5432:5432"
    volumes:
      - db_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 10
{{- else if eq .Database "gorm-mysql" }}
  mysql:
    image: mysql:8-debian
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: {{.EntityLower}}_db
      MYSQL_USER: mysql
      MYSQL_PASSWORD: mysql
    ports:
      - "3306:3306"
    volumes:
      - db_data:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 5s
      timeout: 5s
      retries: 10
{{- end }}
{{- end }}
{{- if eq .Cache "redis" }}

  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 5s
      retries: 10
{{- end }}
{{- if eq .Cache "couchbase" }}

  couchbase:
    image: couchbase:enterprise-7.6.4
    ports:
      - "8091-8096:8091-8096"
      - "11210:11210"
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:8091/pools"]
      interval: 10s
      timeout: 10s
      retries: 15
{{- end }}

  {{.Name}}:
    build:
      context: .
    env_file: .env
{{- if ne .Database "none" }}
    environment:
{{- if eq .Database "gorm-postgres" }}
      DATABASE_DSN: host=postgres port=5432 user=postgres password=postgres dbname={{.EntityLower}}_db sslmode=disable
{{- else if eq .Database "gorm-mysql" }}
      DATABASE_DSN: mysql:mysql@tcp(mysql:3306)/{{.EntityLower}}_db?charset=utf8mb4&parseTime=True&loc=Local
{{- end }}
{{- if eq .Cache "redis" }}
      REDIS_ADDR: redis:6379
{{- else if eq .Cache "couchbase" }}
      COUCHBASE_URL: couchbase://couchbase
{{- end }}
    depends_on:
{{- if eq .Database "gorm-postgres" }}
      postgres:
        condition: service_healthy
{{- else if eq .Database "gorm-mysql" }}
      mysql:
        condition: service_healthy
{{- end }}
{{- if eq .Cache "redis" }}
      redis:
        condition: service_healthy
{{- else if eq .Cache "couchbase" }}
      couchbase:
        condition: service_healthy
{{- end }}
{{- else if eq .Cache "redis" }}
    environment:
      REDIS_ADDR: redis:6379
    depends_on:
      redis:
        condition: service_healthy
{{- else if eq .Cache "couchbase" }}
    environment:
      COUCHBASE_URL: couchbase://couchbase
    depends_on:
      couchbase:
        condition: service_healthy
{{- end }}
    ports:
      - "8080:8080"
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:8080/healthz || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: on-failure
{{- if ne .Database "none" }}

volumes:
  db_data:
{{- end }}
