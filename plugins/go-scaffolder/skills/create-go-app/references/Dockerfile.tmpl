# Stage 1: build
FROM golang:1.26.2-alpine AS builder
RUN apk update && apk add --no-cache git ca-certificates
WORKDIR /app
COPY go.mod go.sum ./
# go-lib is a public module (github.com/labspangaea/go-lib), so `go mod download`
# fetches it and every other dependency straight from the public proxy — nothing
# to authenticate.
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /app/server ./cmd/{{.Name}}

# Stage 2: runtime
FROM alpine:latest
RUN apk --no-cache add ca-certificates tzdata && \
    addgroup -S app && \
    adduser -S -G app app
COPY --chown=app:app --from=builder /app/server /server
USER app
EXPOSE 8080
CMD ["/server"]
