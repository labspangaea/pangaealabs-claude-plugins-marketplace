<% for (const f of Fields) { var bt = baseType(f.GoType); var inner; if (bt === 'number') { inner = 't.Number()'; } else if (bt === 'boolean') { inner = 't.Boolean()'; } else { inner = 't.String()'; } if (isNullable(f.GoType)) { inner = `t.Union([${inner}, t.Null()])`; } %>  <%= f.JSONName %>: <%= inner %>,
<% } %>  created_at: t.String(),
  updated_at: t.String(),
});
