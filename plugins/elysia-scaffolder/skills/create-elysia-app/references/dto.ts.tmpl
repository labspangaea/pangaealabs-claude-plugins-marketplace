/** Create/Update request body. Required fields omit Optional; maxLength enforced. */
export const <%= Entity %>Body = t.Object({
<% for (const f of Fields) { var bt = baseType(f.GoType); var ml = parseMaxLength(f.Validate); var inner; if (bt === 'string') { inner = ml > 0 ? `t.String({ maxLength: ${ml} })` : 't.String()'; } else if (bt === 'number') { inner = 't.Number()'; } else if (bt === 'boolean') { inner = 't.Boolean()'; } else if (bt === 'Date') { inner = "t.String({ format: 'date-time' })"; } else { inner = 't.String()'; } if (isNullable(f.GoType)) { inner = `t.Union([${inner}, t.Null()])`; } if (!isRequired(f.Validate)) { inner = `t.Optional(${inner})`; } %>  <%= f.JSONName %>: <%= inner %>,
<% } %>});
export type <%= Entity %>BodyType = Static<typeof <%= Entity %>Body>;

/** Response shape (snake_case wire); timestamps serialized as ISO strings. */
export const <%= Entity %>Response = t.Object({
