    id: o.id,
<% for (const f of Fields) { %>    <%= f.JSONName %>: <% if (baseType(f.GoType) === 'Date') { %>o.<%= f.Name %>.toISOString()<% } else { %>o.<%= f.Name %><% } %>,
<% } %>    created_at: o.createdAt.toISOString(),
