{
  "name": "<%= Name %>",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "seed": "bun run src/cmd/seed.ts",
    "build": "bun build ./src/index.ts --target bun --outdir dist",
    "build:stub": "bun build ./src/index.ts --target bun --define SERVICE_STUB=true --outdir dist-stub",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@labspangaea/ts-lib": "^0.1.0",
    "@sinclair/typebox": "^0.34.0",
    "drizzle-orm": "^0.38.0",
    "elysia": "^1.2.0",
<% if (Type === 'api') { %>    "@elysiajs/openapi": "^1.4.0",
<% } %>    "ioredis": "^5.4.1",
<% if (Cache === 'couchbase') { %>    "couchbase": "^4.7.0",
<% } %><% if (Type !== 'api' && Broker === 'kafka') { %>    "kafkajs": "^2.2.4",
<% } %><% if (Type !== 'api' && Broker === 'rabbitmq') { %>    "amqplib": "^2.0.1",
<% } %>    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
<% if (Type !== 'api' && Broker === 'rabbitmq') { %>    "@types/amqplib": "^0.10.8",
<% } %>    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
