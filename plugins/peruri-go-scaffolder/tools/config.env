# peruri-go-scaffolder — single source of truth for go-peruri-lib coordinates.
#
# Sourced by tools/sync-go-peruri-lib.sh and read at startup by tools/smoke
# (Go program). The plugin's SKILL.md and README also reference these names —
# update them here when the package URL changes.
#
# Format: shell-compatible KEY=VALUE; safe to `set -a; source` from bash and
# scan with simple regex from Go (see tools/smoke/render.go).
#
# IMPORTANT — what this file does NOT cover:
# The 21 .tmpl files under skills/create-go-app/references/ embed the literal
# module path because they render directly into the user's Go source files.
# Same for references/codebase.md (API reference doc) and SKILL.md prose
# (example imports). If the URL ever changes, run a single sed across those
# content files in addition to updating this config:
#
#   PLUGIN=~/projects/claude-plugins/plugins/peruri-go-scaffolder
#   OLD="sipgn-git.bgn.go.id/harry.sitohang/go-peruri-lib"
#   NEW="new.host/path/go-peruri-lib"
#   grep -rl "$OLD" "$PLUGIN" --include='*.tmpl' --include='*.md' \
#     | xargs sed -i '' "s|$OLD|$NEW|g"
#
# Then update PERURI_GO_MODULE / PERURI_REMOTE_HOST / PERURI_REMOTE_PROJECT
# below to match.

# User-level config store (optional): ~/.peruri-go-scaffolder/config.json.
# Resolved with `jq` when available. Precedence for every value below:
#   environment variable  >  ~/.peruri-go-scaffolder/config.json  >  in-repo default
# See skills/create-go-app/references/config-store.md for the full schema.
_PGS_CFG="${HOME}/.peruri-go-scaffolder/config.json"
_pgs_cfg() {
  [ -f "$_PGS_CFG" ] && command -v jq >/dev/null 2>&1 \
    && jq -r --arg k "$1" '.[$k] // empty' "$_PGS_CFG" 2>/dev/null
}

# Local filesystem path of the cloned reference library.
# Override with `PERURI_GO_LIB_PATH` env or `libLocalPath` in config.json.
PERURI_GO_LIB_PATH="${PERURI_GO_LIB_PATH:-$(_pgs_cfg libLocalPath)}"
PERURI_GO_LIB_PATH="${PERURI_GO_LIB_PATH:-$HOME/go/src/sipgn-git.bgn.go.id/harry.sitohang/go-peruri-lib}"

# GitLab host serving the repo. Used when constructing the clone URL with the
# embedded access token, and as the GOPRIVATE host.
# Override with `PERURI_REMOTE_HOST` env or `remoteHost` in config.json.
PERURI_REMOTE_HOST="${PERURI_REMOTE_HOST:-$(_pgs_cfg remoteHost)}"
PERURI_REMOTE_HOST="${PERURI_REMOTE_HOST:-sipgn-git.bgn.go.id}"

# GitLab project path (namespace/repo) — appended to the host to build the
# full clone URL. Do NOT include the .git suffix.
# Override with `PERURI_REMOTE_PROJECT` env or `remoteProject` in config.json.
PERURI_REMOTE_PROJECT="${PERURI_REMOTE_PROJECT:-$(_pgs_cfg remoteProject)}"
PERURI_REMOTE_PROJECT="${PERURI_REMOTE_PROJECT:-harry.sitohang/go-peruri-lib}"

# Lib import mode for *generated* projects:
#   git   — fetch from the module path via GOPRIVATE (default; no replace directive)
#   local — add `replace <module> => $PERURI_GO_LIB_PATH` to the generated go.mod
# Override with `PERURI_GO_LIB_MODE` env or `libMode` in config.json.
PERURI_GO_LIB_MODE="${PERURI_GO_LIB_MODE:-$(_pgs_cfg libMode)}"
PERURI_GO_LIB_MODE="${PERURI_GO_LIB_MODE:-git}"

# Go module path declared in go-peruri-lib's go.mod. Used by tools/smoke when
# generating a go.mod for scratch builds, and as the replace target in local
# mode. This is the import path baked into generated source — changing it is the
# deep "rehome" operation described in the top comment, NOT a config-store knob.
PERURI_GO_MODULE="${PERURI_GO_MODULE:-sipgn-git.bgn.go.id/harry.sitohang/go-peruri-lib}"
