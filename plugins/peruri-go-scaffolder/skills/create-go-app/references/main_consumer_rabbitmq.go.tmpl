// Package main is the composition root for the {{.Name}} consumer service.
package main

import (
	"context"
	"log/slog"
	"os"
	"os/signal"
	"syscall"

	"github.com/rabbitmq/amqp091-go"
{{- if ne .Database "none" }}
	"sipgn-git.bgn.go.id/harry.sitohang/go-peruri-lib/db"
{{- end }}
	"sipgn-git.bgn.go.id/harry.sitohang/go-peruri-lib/logger"
	"sipgn-git.bgn.go.id/harry.sitohang/go-peruri-lib/pubsub/rabbitmq"
	"sipgn-git.bgn.go.id/harry.sitohang/go-peruri-lib/telemetry"
{{- if eq .Database "gorm-postgres" }}
	"gorm.io/driver/postgres"
{{- else if eq .Database "gorm-mysql" }}
	"gorm.io/driver/mysql"
{{- end }}
{{- if ne .Cache "none" }}
	dbrepo "sipgn-git.bgn.go.id/harry.sitohang/go-peruri-lib/db/repo"
{{- end }}
{{- if eq .Cache "redis" }}
	goredis "github.com/redis/go-redis/v9"
	cacheredis "sipgn-git.bgn.go.id/harry.sitohang/go-peruri-lib/cache/redis"
{{- end }}
{{- if eq .Cache "memory" }}
	cachemem "sipgn-git.bgn.go.id/harry.sitohang/go-peruri-lib/cache/memory"
{{- end }}
{{- if eq .Cache "couchbase" }}
	"github.com/couchbase/gocb/v2"
	cachecb "sipgn-git.bgn.go.id/harry.sitohang/go-peruri-lib/cache/couchbase"
{{- end }}

	"{{.Module}}/config"
	"{{.Module}}/internal/adapter/inbound/subscriber"
{{- if ne .Database "none" }}
	"{{.Module}}/internal/adapter/outbound/repository"
{{- end }}
	"{{.Module}}/internal/service"
)

func main() {
	cfg := config.Load()

	log := logger.New(
		logger.WithServiceInfo(cfg.ServiceName, cfg.Version, cfg.InstanceID),
	)
	ctx := logger.WithLogger(context.Background(), log)

	otelOpts := []telemetry.Option{
		telemetry.WithEndpoint(cfg.OTelEndpoint),
		telemetry.WithProtocol(cfg.OTelProtocol),
		telemetry.WithServiceInfo(cfg.ServiceName, cfg.Version, cfg.InstanceID),
	}
	if cfg.OTelInsecure {
		otelOpts = append(otelOpts, telemetry.WithInsecure())
	}
	if len(cfg.OTelHeaders) > 0 {
		otelOpts = append(otelOpts, telemetry.WithHeaders(cfg.OTelHeaders))
	}
	_, lp, otelShutdown, err := telemetry.Setup(ctx, otelOpts...)
	if err != nil {
		log.Warn("telemetry setup failed, continuing without tracing",
			slog.Any(logger.KeyError, err),
		)
	} else {
		defer otelShutdown(ctx)
	}

	// Optional: stream high-severity slog records to OTLP via the OTel log bridge.
	if err == nil && cfg.OTelLogBridgeEnabled && lp != nil {
		log = logger.New(
			logger.WithServiceInfo(cfg.ServiceName, cfg.Version, cfg.InstanceID),
			logger.WithOTelBridge(lp, cfg.OTelLogMinSeverity),
		)
		ctx = logger.WithLogger(ctx, log)
	}

{{- if ne .Database "none" }}

	gormDB, err := db.Open(
{{- if eq .Database "gorm-postgres" }}postgres.Open(cfg.DatabaseDSN){{else if eq .Database "gorm-mysql" }}mysql.Open(cfg.DatabaseDSN){{end}},
		db.WithMaxOpenConns(cfg.DBMaxOpen),
		db.WithSlowThreshold(cfg.DBSlowThreshold),
	)
	if err != nil {
		log.Error("database connection failed", slog.Any(logger.KeyError, err))
		os.Exit(1)
	}
	defer db.Close(gormDB)
{{- end }}

{{- if eq .Cache "redis" }}

	redisClient := goredis.NewClient(&goredis.Options{
		Addr:     cfg.RedisAddr,
		Password: cfg.RedisPassword,
		DB:       cfg.RedisDB,
	})
	defer redisClient.Close()
	{{.EntityLower}}Cache := cacheredis.New[*repository.{{.Entity}}Model](redisClient)
{{- else if eq .Cache "memory" }}

	{{.EntityLower}}Cache := cachemem.New[*repository.{{.Entity}}Model](
		cachemem.WithCapacity[*repository.{{.Entity}}Model](cfg.MemoryCacheCapacity),
	)
{{- else if eq .Cache "couchbase" }}

	cluster, err := gocb.Connect(cfg.CouchbaseURL, gocb.ClusterOptions{
		Username: cfg.CouchbaseUsername,
		Password: cfg.CouchbasePassword,
	})
	if err != nil {
		log.Error("couchbase connect failed", slog.Any(logger.KeyError, err))
		os.Exit(1)
	}
	defer cluster.Close(nil)
	col := cluster.Bucket(cfg.CouchbaseBucket).DefaultCollection()
	{{.EntityLower}}Cache := cachecb.New[*repository.{{.Entity}}Model](col)
{{- end }}

{{- if ne .Database "none" }}

{{- if ne .Cache "none" }}
	{{.EntityLower}}Repo := repository.NewCached(gormDB, {{.EntityLower}}Cache,
		dbrepo.WithTTL(cfg.CacheTTL),
		dbrepo.WithJitter(cfg.CacheJitterFactor),
		dbrepo.WithTwoPhaseList(),
	)
{{- else }}
	{{.EntityLower}}Repo := repository.New(gormDB)
{{- end }}
	svc := service.New({{.EntityLower}}Repo)
{{- else }}

	svc := service.New(nil)
{{- end }}

	conn, err := amqp091.Dial(cfg.RabbitMQURL)
	if err != nil {
		log.Error("rabbitmq dial failed", slog.Any(logger.KeyError, err))
		os.Exit(1)
	}
	defer conn.Close()

	consumer := rabbitmq.NewConsumer(conn, cfg.Topic)
	defer consumer.Close()

	handler := subscriber.NewHandler(svc)

	ctx, stop := signal.NotifyContext(ctx, syscall.SIGINT, syscall.SIGTERM)
	defer stop()

	log.Info("consumer starting",
		slog.String("exchange", cfg.Topic),
		slog.String("queue", cfg.ConsumerGroup),
	)

	if err := consumer.Subscribe(ctx, cfg.Topic, cfg.ConsumerGroup, handler.Handle); err != nil {
		log.Error("consumer subscribe error", slog.Any(logger.KeyError, err))
		os.Exit(1)
	}

	log.Info("consumer shutdown complete")
}
