{{- if eq .Database "gorm-postgres" -}}
DATABASE_DSN=host=localhost port=5432 user=postgres password=postgres dbname={{.EntityLower}}_db sslmode=disable
{{- else if eq .Database "gorm-mysql" -}}
DATABASE_DSN=mysql:mysql@tcp(localhost:3306)/{{.EntityLower}}_db?charset=utf8mb4&parseTime=True&loc=Local
{{- end }}
{{- if eq .Cache "redis" }}
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
{{- end }}
{{- if eq .Cache "memory" }}
MEMORY_CACHE_CAPACITY=1000
{{- end }}
{{- if eq .Cache "couchbase" }}
COUCHBASE_URL=couchbase://localhost
COUCHBASE_USERNAME=Administrator
COUCHBASE_PASSWORD=password
COUCHBASE_BUCKET={{.EntityLower}}_db
{{- end }}
DOCS_ENABLED=true
DB_LOG_LEVEL=info
LOG_BODY=true
HTTP_ADDR=:8080
{{- if eq .Type "api" }}

# Service backend selector. Only effective when the binary was built with
# `-tags=stub` (e.g. `go run -tags=stub ./cmd/{{.Name}}`). Production builds
# (`go build ./cmd/{{.Name}}`) ignore this value and always wire the real
# service — the stub package is not linked in.
#
#   stub = canned-response stub. No DB / cache / broker required. Frontend
#          can integrate against the huma OpenAPI contract while backend
#          business logic is still in progress. Stateless — Create/Update/
#          Delete return success but do not persist; List/Find return a
#          fixed 25-record sample.
#   real = production service. Requires whatever the real service needs
#          (database, cache, etc.).
SERVICE_BACKEND=stub
{{- end }}
