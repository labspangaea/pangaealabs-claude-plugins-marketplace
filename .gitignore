.DS_Store
__pycache__/
*.pyc

# installer deps (the npx installer's package.json deps are restored on demand)
node_modules/

# dev/eval workspaces (kept locally, never shipped); bulky iteration run-outputs
# (rendered PDFs, grading/timing JSON, review HTML) are regenerable — never tracked.
dev/*/iteration-*/

# local tooling state — not repo content
.claude/skills/
# impeccable critique snapshots
.impeccable/
# ad-hoc rendered demo PDFs at repo root
*-optimized.pdf
